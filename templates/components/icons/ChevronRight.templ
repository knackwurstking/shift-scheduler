package icons

type ChevronRightProps struct {
	Class string
}

templ ChevronRight(props ...ChevronRightProps) {
	{{
		p := ChevronRightProps{}
		if len(props) > 0 {
			p = props[0]
		}
	}}
	<svg
		width="24"
		height="24"
		viewBox="0 0 24 24"
		fill="none"
		xmlns="http://www.w3.org/2000/svg"
		class={ p.Class }
	>
		<path
			d="M9 18L15 12L9 6"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
		></path>
	</svg>
}
